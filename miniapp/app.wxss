page {
  min-height: 100vh;
  background: #f7f7f8;
  color: #20242a;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 1;
  min-height: 0;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 20rpx;
}

.section {
  margin-bottom: 24rpx;
}

.panel {
  background: #ffffff;
  border: 1rpx solid #eceef2;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(30, 34, 40, 0.055);
}

.primary-btn {
  height: 80rpx;
  padding: 0 28rpx;
  border-radius: 16rpx;
  background: #ff6a00;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 900;
}

.secondary-btn {
  height: 64rpx;
  padding: 0 22rpx;
  border-radius: 14rpx;
  background: #fff1e8;
  color: #ff6a00;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
}

.muted {
  color: #7a7f87;
}

.price {
  color: #ff6a00;
  font-weight: 700;
}

.empty {
  padding: 96rpx 32rpx;
  text-align: center;
  color: #7a7f87;
}
