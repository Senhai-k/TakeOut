<view class="page address-list-page">
  <view wx:for="{{addresses}}" wx:key="id" class="panel address-card">
    <view class="address-main" bindtap="selectAddress" data-id="{{item.id}}">
      <view class="address-title">
        {{item.receiverName}} {{item.receiverPhone}}
        <text wx:if="{{item.isDefault}}" class="default-tag">默认</text>
      </view>
      <view class="address-detail">{{item.province}}{{item.city}}{{item.district}}{{item.detail}} {{item.houseNumber}}</view>
    </view>
    <view class="address-actions">
      <button class="edit-btn" bindtap="editAddress" data-id="{{item.id}}">编辑</button>
      <button class="delete-btn" bindtap="removeAddress" data-id="{{item.id}}">删除</button>
    </view>
  </view>

  <view wx:if="{{addresses.length === 0}}" class="panel empty">暂无地址</view>

  <button class="primary-btn add-btn" bindtap="addAddress">新增地址</button>
</view>
