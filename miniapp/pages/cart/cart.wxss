.cart-page {
  min-height: 100vh;
  padding: 20rpx 20rpx 136rpx;
  background: #f7f7f8;
}

.cart-header {
  height: 58rpx;
  margin-bottom: 18rpx;
  display: flex;
  align-items: center;
}

.back-arrow {
  width: 48rpx;
  height: 48rpx;
  margin-right: 12rpx;
  border-radius: 50%;
  background: #ffffff;
  color: #20242a;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  box-shadow: 0 8rpx 20rpx rgba(30, 34, 40, 0.06);
}

.page-title {
  font-size: 36rpx;
  font-weight: 900;
}

.cart-list {
  margin-bottom: 16rpx;
  overflow: hidden;
}

.shop-row {
  height: 76rpx;
  padding: 0 18rpx;
  border-bottom: 1rpx solid #eef0f3;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.shop-name {
  color: #20242a;
  font-weight: 900;
}

.clear-cart {
  height: 48rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #f2f3f5;
  color: #68707b;
  display: flex;
  align-items: center;
  font-size: 22rpx;
  font-weight: 700;
}

.cart-empty {
  padding: 72rpx 32rpx;
  text-align: center;
}

.empty-icon {
  font-size: 72rpx;
}

.empty-title {
  margin-top: 20rpx;
  color: #20242a;
  font-size: 32rpx;
  font-weight: 900;
}

.empty-desc {
  margin-top: 10rpx;
  color: #8a8f98;
  font-size: 24rpx;
}

.empty-btn {
  width: 188rpx;
  height: 64rpx;
  margin: 28rpx auto 0;
  border-radius: 14rpx;
  background: #ff6a00;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
}

.cart-item {
  min-height: 116rpx;
  padding: 16rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #eef0f3;
}

.cart-item:last-child {
  border-bottom: 0;
}

.thumb {
  width: 76rpx;
  height: 76rpx;
  border-radius: 16rpx;
  background: #fff1e8;
  color: #ff6a00;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 900;
}

.item-main {
  flex: 1;
  min-width: 0;
  padding: 0 16rpx;
}

.item-name {
  margin-bottom: 8rpx;
  font-weight: 800;
}

.item-option {
  margin-bottom: 6rpx;
  color: #9a5a24;
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-side {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.item-price {
  color: #ff6a00;
  font-weight: 900;
}

.qty-stepper {
  height: 46rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.step-btn {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #f2f3f5;
  color: #60666f;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 44rpx;
}

.step-btn.add {
  background: #ff6a00;
  color: #ffffff;
}

.qty-num {
  min-width: 30rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 800;
}

.promo {
  height: 86rpx;
  margin-bottom: 16rpx;
  padding: 10rpx;
  display: flex;
  align-items: center;
}

.promo input {
  flex: 1;
  height: 66rpx;
  padding: 0 18rpx;
}

.promo button {
  width: 126rpx;
  height: 62rpx;
  border-radius: 14rpx;
  background: #ff6a00;
  color: #ffffff;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.summary {
  padding: 14rpx 22rpx;
}

.summary-row {
  min-height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #68707b;
}

.summary-row.total {
  margin-top: 6rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #eef0f3;
  color: #ff6a00;
  font-size: 32rpx;
  font-weight: 900;
}

.summary-row.warning {
  color: #d46b08;
}

.checkout {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: calc(16rpx + env(safe-area-inset-bottom));
  height: 80rpx;
  border-radius: 16rpx;
  background: #ff6a00;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 900;
}

.checkout.disabled {
  background: #c8ccd3;
  color: #ffffff;
}
