<view class="page address-edit-page">
  <view class="panel form-panel">
    <view class="field">
      <view class="label">收货人</view>
      <input value="{{form.receiverName}}" placeholder="请输入收货人" data-field="receiverName" bindinput="onInput" />
    </view>
    <view class="field">
      <view class="label">手机号</view>
      <input value="{{form.receiverPhone}}" placeholder="请输入手机号" type="number" data-field="receiverPhone" bindinput="onInput" />
    </view>
    <view class="field">
      <view class="label">省份</view>
      <input value="{{form.province}}" placeholder="如 广东省" data-field="province" bindinput="onInput" />
    </view>
    <view class="field">
      <view class="label">城市</view>
      <input value="{{form.city}}" placeholder="如 深圳市" data-field="city" bindinput="onInput" />
    </view>
    <view class="field">
      <view class="label">区域</view>
      <input value="{{form.district}}" placeholder="如 南山区" data-field="district" bindinput="onInput" />
    </view>
    <view class="field">
      <view class="label">详细地址</view>
      <input value="{{form.detail}}" placeholder="街道、小区、楼栋" data-field="detail" bindinput="onInput" />
    </view>
    <view class="field">
      <view class="label">门牌号</view>
      <input value="{{form.houseNumber}}" placeholder="如 A 座 1001" data-field="houseNumber" bindinput="onInput" />
    </view>
    <view class="field switch-field">
      <view>
        <view class="label">默认地址</view>
        <view class="hint">下单时优先使用</view>
      </view>
      <switch checked="{{form.isDefault}}" color="#188b57" bindchange="onDefaultChange" />
    </view>
  </view>

  <button class="primary-btn save-btn" bindtap="saveAddress">保存地址</button>
</view>
