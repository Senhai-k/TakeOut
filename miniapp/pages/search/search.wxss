.search-page {
  min-height: 100vh;
  padding: 20rpx;
  background: #f6f7f9;
}

.search-box {
  height: 82rpx;
  margin-bottom: 24rpx;
  padding: 0 18rpx 0 24rpx;
  border-radius: 16rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(30, 34, 40, 0.055);
}

.search-icon {
  margin-right: 12rpx;
  color: #ff6a00;
  font-size: 32rpx;
}

.search-box input {
  flex: 1;
  height: 72rpx;
}

.clear-btn {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #f0f2f5;
  color: #8a8f98;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
}

.section {
  margin-bottom: 26rpx;
}

.section-title {
  margin-bottom: 16rpx;
  color: #20242a;
  font-size: 30rpx;
  font-weight: 900;
}

.tag-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.hot-tag {
  height: 56rpx;
  padding: 0 20rpx;
  border-radius: 14rpx;
  background: #ffffff;
  color: #4f5965;
  display: flex;
  align-items: center;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(30, 34, 40, 0.045);
}

.filter-scroll {
  width: 100%;
  white-space: nowrap;
}

.filter-strip {
  display: flex;
  gap: 14rpx;
  padding-right: 24rpx;
}

.filter-item {
  height: 58rpx;
  padding: 0 22rpx;
  border-radius: 14rpx;
  background: #ffffff;
  color: #60666f;
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  box-shadow: 0 8rpx 20rpx rgba(30, 34, 40, 0.05);
}

.filter-item.active {
  background: #20242a;
  color: #ffffff;
  font-weight: 800;
}

.result-section {
  padding-bottom: 20rpx;
}

.result-card {
  min-height: 136rpx;
  margin-bottom: 16rpx;
  padding: 16rpx;
  display: flex;
  align-items: center;
  border-radius: 16rpx;
}

.result-thumb {
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
  overflow: hidden;
}

.result-thumb view {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.72);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
}

.result-thumb.pizza {
  background: linear-gradient(135deg, #ffe0c4, #e85c35);
}

.result-thumb.ramen {
  background: linear-gradient(135deg, #fff0b6, #36a27a);
}

.result-thumb.bbq {
  background: linear-gradient(135deg, #ffd2be, #7d4b30);
}

.result-thumb.drink {
  background: linear-gradient(135deg, #d8f6e5, #54b984);
}

.result-thumb.snack {
  background: linear-gradient(135deg, #ffe3cf, #e8914a);
}

.result-main {
  flex: 1;
  min-width: 0;
  padding: 0 18rpx;
}

.result-name {
  flex: 1;
  min-width: 0;
  color: #20242a;
  font-size: 28rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.result-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.type-badge {
  height: 36rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  font-size: 20rpx;
  font-weight: 800;
}

.type-badge.dish {
  background: #fff4d7;
  color: #8a5b00;
}

.type-badge.merchant {
  background: #edf8f3;
  color: #0b8a57;
}

.result-desc,
.result-meta {
  margin-top: 8rpx;
  color: #7a7f87;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.result-meta {
  display: flex;
  gap: 14rpx;
}

.result-action {
  width: 72rpx;
  height: 52rpx;
  border-radius: 12rpx;
  background: #20242a;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
}
