<view class="merchant-detail-page">
  <view wx:if="{{order}}">
    <view class="top-row">
      <view class="order-title-block">
        <view class="title">订单 {{order.displayNo}}</view>
        <view class="status-text">{{order.statusText}}</view>
      </view>
      <button class="back-btn" bindtap="goBack">返回</button>
    </view>

    <view class="panel status-card">
      <view class="section-title">处理进度</view>
      <view wx:for="{{steps}}" wx:key="title" class="step {{item.state}}">
        <view class="step-dot">{{item.state === 'done' ? '✓' : ''}}</view>
        <view class="step-main">
          <view class="step-title">{{item.title}}</view>
          <view class="step-desc">{{item.desc}}</view>
        </view>
      </view>
    </view>

    <view class="panel item-panel">
      <view class="section-title">商品明细</view>
      <view wx:for="{{order.items}}" wx:key="cartKey" class="detail-item">
        <view class="item-image">{{item.initial || '餐'}}</view>
        <view class="item-main">
          <view class="detail-name">{{item.dishName}}</view>
          <view wx:if="{{item.optionText}}" class="muted">{{item.optionText}}</view>
          <view class="muted">x{{item.quantity}}</view>
        </view>
        <view>¥{{item.subtotalAmount}}</view>
      </view>
      <view class="amount-row">
        <text>商品金额</text>
        <text>¥{{order.goodsAmountText}}</text>
      </view>
      <view class="amount-row">
        <text>配送费</text>
        <text>¥{{order.deliveryFeeText}}</text>
      </view>
      <view class="amount-row total">
        <text>合计</text>
        <text>¥{{order.payAmountText}}</text>
      </view>
    </view>

    <view class="panel info-panel">
      <view class="section-title">配送信息</view>
      <view class="info-row">
        <text class="info-label">收货人</text>
        <text class="info-value">{{order.receiverName}} {{order.receiverPhone}}</text>
      </view>
      <view class="info-row address-line">
        <text class="info-label">收货地址</text>
        <text class="info-value">{{order.receiverAddress}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">备注</text>
        <text class="info-value">{{order.remark || '无'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">下单时间</text>
        <text class="info-value">{{order.createdAt}}</text>
      </view>
    </view>

    <view class="bottom-actions">
      <button wx:if="{{order.canReject}}" class="ghost-btn" bindtap="rejectOrder">拒单</button>
      <button wx:if="{{order.canAccept}}" class="primary-btn" bindtap="acceptOrder">接单</button>
      <button wx:if="{{order.canToCooking}}" class="primary-btn" bindtap="updateStatus" data-status="40">制作中</button>
      <button wx:if="{{order.canToDelivering}}" class="primary-btn" bindtap="updateStatus" data-status="50">配送中</button>
      <button wx:if="{{order.canFinish}}" class="primary-btn" bindtap="updateStatus" data-status="60">已完成</button>
    </view>
  </view>

  <view wx:else class="panel empty">订单不存在</view>
</view>
