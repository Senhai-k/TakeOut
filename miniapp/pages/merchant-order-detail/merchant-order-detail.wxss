.merchant-detail-page {
  min-height: 100vh;
  padding: 20rpx 16rpx 148rpx;
  background: #f2f3f5;
}

.top-row {
  min-height: 82rpx;
  margin-bottom: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.order-title-block {
  flex: 1;
  min-width: 0;
}

.title {
  color: #20242a;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.15;
}

.status-text,
.muted {
  color: #8a8f98;
  font-size: 25rpx;
  line-height: 1.45;
}

.back-btn {
  width: 160rpx;
  height: 60rpx;
  border-radius: 14rpx;
  background: #fff1e8;
  color: #ff6500;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 26rpx;
  font-weight: 900;
}

.status-card,
.item-panel,
.info-panel,
.review-panel {
  margin-bottom: 14rpx;
  padding: 22rpx;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(30, 34, 40, 0.045);
}

.section-title {
  margin-bottom: 18rpx;
  color: #20242a;
  font-weight: 900;
  font-size: 29rpx;
}

.step {
  position: relative;
  min-height: 84rpx;
  display: flex;
}

.step:not(:last-child)::after {
  content: "";
  position: absolute;
  left: 20rpx;
  top: 42rpx;
  bottom: -10rpx;
  width: 4rpx;
  border-radius: 999rpx;
  background: #e1e5eb;
}

.step.done:not(:last-child)::after {
  background: #ff6500;
}

.step-dot {
  position: relative;
  z-index: 1;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #dfe4ea;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
  flex-shrink: 0;
}

.step.done .step-dot {
  background: #ff6500;
}

.step.current .step-dot {
  background: #ffffff;
  border: 8rpx solid #ff6500;
}

.step-main {
  min-width: 0;
  padding-left: 18rpx;
  padding-bottom: 18rpx;
}

.step-title {
  color: #20242a;
  font-size: 29rpx;
  font-weight: 900;
}

.step-desc {
  margin-top: 6rpx;
  color: #8a8f98;
  font-size: 24rpx;
}

.detail-item {
  min-height: 96rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.item-image {
  width: 62rpx;
  height: 62rpx;
  border-radius: 14rpx;
  background: #fff1e8;
  color: #ff6500;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-weight: 900;
}

.item-main {
  flex: 1;
  min-width: 0;
}

.detail-name {
  color: #20242a;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.amount-row {
  min-height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #68707b;
  font-size: 25rpx;
}

.amount-row.total {
  margin-top: 12rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #eef0f3;
  color: #ff6500;
  font-size: 32rpx;
  font-weight: 900;
}

.info-row {
  min-height: 56rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  color: #68707b;
  font-size: 25rpx;
  line-height: 1.45;
}

.info-label {
  flex-shrink: 0;
}

.info-value {
  color: #20242a;
  text-align: right;
}

.address-line .info-value {
  max-width: 480rpx;
}

.review-stars {
  display: flex;
  gap: 8rpx;
}

.star {
  color: #d8dde5;
  font-size: 34rpx;
}

.star.active {
  color: #ff9f1a;
}

.review-content {
  margin-top: 14rpx;
  color: #20242a;
  font-size: 26rpx;
  line-height: 1.5;
}

.review-time {
  margin-top: 10rpx;
  color: #8a8f98;
  font-size: 23rpx;
}

.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  min-height: 108rpx;
  padding: 12rpx 20rpx calc(12rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #eceef2;
  display: flex;
  gap: 16rpx;
  z-index: 20;
}

.primary-btn,
.ghost-btn {
  flex: 1;
  min-width: 0;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
}

.primary-btn {
  background: #ff6500;
  color: #ffffff;
}

.ghost-btn {
  background: #fff1e8;
  color: #ff6500;
}

.empty {
  padding: 96rpx 32rpx;
  text-align: center;
  color: #8a8f98;
}
