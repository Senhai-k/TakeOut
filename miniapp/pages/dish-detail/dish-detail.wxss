.detail-page {
  min-height: 100vh;
  padding-bottom: 132rpx;
  background: #ffffff;
}

.hero {
  position: relative;
  height: 460rpx;
  background: linear-gradient(135deg, #ffe0c2, #ff8a2a);
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-food {
  width: 288rpx;
  height: 288rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.72);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 132rpx;
  box-shadow: 0 20rpx 44rpx rgba(129, 60, 0, 0.2);
}

.hero-overlay {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  min-height: 76rpx;
  padding: 14rpx 20rpx;
  border-radius: 16rpx;
  background: rgba(32, 36, 42, 0.72);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-weight: 800;
}

.rating {
  color: #ffd166;
}

.content {
  padding: 26rpx 22rpx;
}

.item-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.item-name {
  font-size: 36rpx;
  line-height: 1.18;
  font-weight: 900;
}

.item-desc {
  margin-top: 12rpx;
  color: #68707b;
  line-height: 1.55;
  font-size: 26rpx;
}

.item-head .price {
  flex-shrink: 0;
  font-size: 32rpx;
}

.option-section {
  margin-bottom: 28rpx;
}

.option-title {
  margin-bottom: 14rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.segment {
  height: 70rpx;
  padding: 6rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
  display: flex;
}

.segment-item {
  flex: 1;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #68707b;
  font-weight: 700;
}

.segment-item.active {
  background: #ffffff;
  color: #ff6a00;
  box-shadow: 0 6rpx 18rpx rgba(30, 34, 40, 0.08);
}

.radio-row {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
}

.radio-item {
  min-height: 58rpx;
  padding: 0 16rpx;
  border-radius: 14rpx;
  background: #fff7f1;
  display: flex;
  align-items: center;
}

.notes {
  width: 100%;
  min-height: 150rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
}

.add-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  min-height: 108rpx;
  padding: 12rpx 20rpx calc(12rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #eceef2;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.qty-box {
  width: 168rpx;
  height: 76rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: space-around;
  font-weight: 800;
}

.qty-btn {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #ffffff;
  color: #ff6a00;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.qty-btn.add {
  background: #ff6a00;
  color: #ffffff;
}

.add-cart {
  flex: 1;
  height: 76rpx;
  border-radius: 16rpx;
  background: #ff6a00;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  font-size: 27rpx;
}
