<view class="merchant-orders-page">
  <view wx:if="{{overview}}" class="overview-card">
    <view class="overview-item">
      <view class="overview-value">{{overview.todayOrderCount}}</view>
      <view class="overview-label">今日订单</view>
    </view>
    <view class="overview-item">
      <view class="overview-value">¥{{overview.todaySalesAmountText}}</view>
      <view class="overview-label">今日销售额</view>
    </view>
    <view class="overview-item">
      <view class="overview-value">{{overview.pendingOrderCount}}</view>
      <view class="overview-label">待接单</view>
    </view>
    <view class="overview-item">
      <view class="overview-value">{{overview.dishCount}}</view>
      <view class="overview-label">在售菜品</view>
    </view>
  </view>

  <scroll-view class="status-tabs" scroll-x enable-flex>
    <view class="status-tab-strip">
      <view
        wx:for="{{tabs}}"
        wx:key="status"
        class="status-tab {{activeStatus === item.status ? 'active' : ''}}"
        data-status="{{item.status}}"
        bindtap="selectTab"
      >
        {{item.label}}
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{loading}}" class="empty-card">
    <view class="empty-title">加载中...</view>
  </view>

  <view wx:elif="{{orders.length === 0}}" class="empty-card">
    <view class="empty-title">暂无订单</view>
    <view class="empty-desc">等待用户下单后即可在这里处理</view>
  </view>

  <view wx:for="{{orders}}" wx:key="id" class="order-card">
    <view class="order-head" bindtap="goDetail" data-id="{{item.id}}">
      <view class="head-main">
        <view class="shop-name">{{item.shopName}}</view>
        <view class="order-no">{{item.displayNo}}</view>
      </view>
      <view class="status-wrap">
        <view class="status {{item.orderStatus === 20 ? 'waiting' : ''}}">{{item.statusText}}</view>
        <view wx:if="{{item.hasReview}}" class="review-badge">{{item.reviewSummary}}</view>
      </view>
    </view>

    <view class="customer-line" bindtap="goDetail" data-id="{{item.id}}">
      <text>{{item.receiverName}}</text>
      <text>{{item.receiverPhone}}</text>
    </view>
    <view class="address-line" bindtap="goDetail" data-id="{{item.id}}">{{item.receiverAddress}}</view>

    <view class="order-items">
      <view wx:for="{{item.items}}" wx:key="dishId" wx:for-item="dish" class="dish-line">
        <text class="dish-name">{{dish.dishName}}</text>
        <text>x{{dish.quantity}}</text>
      </view>
    </view>

    <view class="order-foot">
      <view>
        <view class="created-at">{{item.createdAt}}</view>
        <view class="item-summary">共 {{item.itemCount}} 件商品</view>
      </view>
      <view class="amount-block">
        <view class="amount">¥{{item.payAmountText}}</view>
        <view class="detail-link" bindtap="goDetail" data-id="{{item.id}}">查看详情</view>
      </view>
    </view>

    <view class="action-row">
      <button wx:if="{{item.canReject}}" class="ghost-btn" bindtap="rejectOrder" data-id="{{item.id}}">拒单</button>
      <button wx:if="{{item.canAccept}}" class="primary-btn" bindtap="acceptOrder" data-id="{{item.id}}">接单</button>
      <button wx:if="{{item.canToCooking}}" class="primary-btn" bindtap="updateStatus" data-id="{{item.id}}" data-status="40">制作中</button>
      <button wx:if="{{item.canToDelivering}}" class="primary-btn" bindtap="updateStatus" data-id="{{item.id}}" data-status="50">配送中</button>
      <button wx:if="{{item.canFinish}}" class="primary-btn" bindtap="updateStatus" data-id="{{item.id}}" data-status="60">已完成</button>
    </view>
  </view>
</view>
