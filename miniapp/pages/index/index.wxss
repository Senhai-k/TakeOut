.home-page {
  min-height: 100vh;
  padding: 22rpx 20rpx 32rpx;
  background: #f6f7f9;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.city-label {
  color: #8a8f98;
  font-size: 22rpx;
}

.city {
  margin-top: 4rpx;
  color: #20242a;
  font-size: 34rpx;
  font-weight: 900;
}

.status-chip,
.scan-icon {
  min-width: 68rpx;
  height: 68rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #edf8f3;
  color: #0b8a57;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
  box-shadow: 0 8rpx 20rpx rgba(22, 132, 88, 0.08);
}

.scan-icon {
  width: 68rpx;
  padding: 0;
  background: #ffffff;
  color: #20242a;
  font-size: 30rpx;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.search-box {
  flex: 1;
  height: 82rpx;
  padding: 0 22rpx;
  border-radius: 16rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 22rpx rgba(30, 34, 40, 0.06);
}

.search-icon {
  margin-right: 10rpx;
  color: #ff6a00;
  font-size: 30rpx;
}

.search-placeholder {
  color: #9aa0aa;
  font-size: 26rpx;
}

.promo-band {
  min-height: 146rpx;
  margin-bottom: 26rpx;
  padding: 26rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #243245, #0f8f6d);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 16rpx 30rpx rgba(23, 54, 67, 0.18);
}

.promo-title {
  font-size: 34rpx;
  font-weight: 900;
}

.promo-desc {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.76);
  font-size: 24rpx;
}

.promo-badge {
  min-width: 164rpx;
  height: 58rpx;
  border-radius: 999rpx;
  background: #ffd45f;
  color: #382808;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
}

.category-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 28rpx;
}

.category-strip {
  display: flex;
  gap: 12rpx;
  padding-right: 20rpx;
}

.category-item {
  width: 116rpx;
  flex-shrink: 0;
  text-align: center;
}

.category-icon {
  width: 92rpx;
  height: 92rpx;
  margin: 0 auto 8rpx;
  border-radius: 20rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  box-shadow: 0 8rpx 20rpx rgba(30, 34, 40, 0.06);
}

.category-name {
  color: #555c66;
  font-size: 23rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  color: #20242a;
  font-size: 34rpx;
  font-weight: 900;
}

.section-more {
  color: #ff6a00;
  font-size: 24rpx;
  font-weight: 700;
}

.merchant-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 24rpx;
}

.merchant-card {
  min-height: 202rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  background: #ffffff;
  display: flex;
  box-shadow: 0 10rpx 28rpx rgba(30, 34, 40, 0.065);
}

.merchant-photo {
  width: 176rpx;
  min-height: 170rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  flex-shrink: 0;
  overflow: hidden;
}

.merchant-photo.pizza {
  background: linear-gradient(135deg, #ffe0c4, #e85c35);
}

.merchant-photo.ramen {
  background: linear-gradient(135deg, #fff0b6, #36a27a);
}

.merchant-photo.bbq {
  background: linear-gradient(135deg, #ffd2be, #7d4b30);
}

.merchant-mark {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.72);
  display: flex;
  align-items: center;
  justify-content: center;
}

.merchant-main {
  flex: 1;
  min-width: 0;
  padding: 4rpx 2rpx 2rpx 18rpx;
}

.merchant-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.merchant-name {
  flex: 1;
  min-width: 0;
  color: #20242a;
  font-size: 30rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rating-pill {
  height: 38rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: #fff4d7;
  color: #8a5b00;
  display: flex;
  align-items: center;
  font-size: 22rpx;
  font-weight: 900;
}

.merchant-meta {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  color: #7a7f87;
  font-size: 23rpx;
}

.merchant-desc {
  margin-top: 10rpx;
  color: #8a8f98;
  font-size: 23rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.merchant-tags {
  margin-top: 14rpx;
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.merchant-tags text {
  height: 40rpx;
  padding: 0 12rpx;
  border-radius: 10rpx;
  background: #f2f5f7;
  color: #60666f;
  display: flex;
  align-items: center;
  font-size: 21rpx;
}
