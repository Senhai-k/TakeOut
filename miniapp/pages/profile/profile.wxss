.profile-page {
  min-height: 100vh;
  padding: 20rpx 20rpx 48rpx;
  background: #f5f6f8;
}

.profile-card {
  min-height: 168rpx;
  padding: 28rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #fff4eb 0%, #ffffff 76%);
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 1rpx solid #f0e7df;
  box-shadow: 0 10rpx 26rpx rgba(30, 34, 40, 0.05);
}

.profile-main {
  min-width: 0;
  display: flex;
  align-items: center;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #ffffff;
  color: #ff6a00;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  font-weight: 900;
  box-shadow: 0 8rpx 18rpx rgba(255, 106, 0, 0.1);
}

.user-main {
  min-width: 0;
  padding-left: 20rpx;
}

.user-name {
  font-size: 34rpx;
  font-weight: 900;
  line-height: 42rpx;
}

.user-meta {
  max-width: 360rpx;
  margin-top: 10rpx;
  color: #8a8f98;
  font-size: 24rpx;
  line-height: 32rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.login-btn {
  width: 144rpx;
  height: 58rpx;
  margin: 0 0 0 20rpx;
  border-radius: 999rpx;
  background: #ff6a00;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 900;
}

.member-tag {
  min-width: 120rpx;
  height: 52rpx;
  margin-left: 20rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #ff6a00;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
}

.stats {
  margin: 18rpx 0 20rpx;
  padding: 22rpx 0;
  display: flex;
}

.stat {
  flex: 1;
  text-align: center;
  border-right: 1rpx solid #eef0f3;
}

.stat:last-child {
  border-right: 0;
}

.stat-value {
  color: #20242a;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 38rpx;
}

.stat-label {
  margin-top: 10rpx;
  color: #8a8f98;
  font-size: 22rpx;
}

.menu-list {
  overflow: hidden;
}

.menu-card {
  min-height: 92rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #f0f1f4;
}

.menu-card:last-child {
  border-bottom: 0;
}

.menu-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  background: #fff1e8;
  color: #ff6a00;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
}

.menu-title {
  flex: 1;
  padding-left: 20rpx;
  color: #20242a;
  font-size: 29rpx;
  font-weight: 800;
}

.menu-extra {
  min-width: 38rpx;
  height: 38rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: #fff1e8;
  color: #ff6a00;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 900;
}

.menu-sub {
  max-width: 168rpx;
  color: #8a8f98;
  font-size: 23rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chevron {
  color: #b3b8c1;
  font-size: 40rpx;
  line-height: 40rpx;
}

.sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.28);
  z-index: 20;
}

.payment-sheet {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: calc(20rpx + env(safe-area-inset-bottom));
  padding: 24rpx;
  border-radius: 20rpx;
  background: #ffffff;
  z-index: 30;
  box-shadow: 0 -10rpx 34rpx rgba(30, 34, 40, 0.16);
}

.sheet-title {
  margin-bottom: 16rpx;
  color: #20242a;
  font-size: 31rpx;
  font-weight: 900;
}

.payment-option {
  min-height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1rpx solid #f0f1f4;
}

.setting-row {
  min-height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  border-top: 1rpx solid #f0f1f4;
}

.payment-name {
  color: #20242a;
  font-size: 28rpx;
  font-weight: 900;
}

.payment-desc {
  margin-top: 6rpx;
  color: #8a8f98;
  font-size: 23rpx;
}

.payment-check {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: #e9ebef;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
}

.payment-check.active {
  background: #ff6a00;
}

.logout {
  height: 80rpx;
  margin-top: 24rpx;
  border-radius: 16rpx;
  background: #e9ebef;
  color: #68707b;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 900;
}

.dev-text {
  margin-top: 18rpx;
  color: #8a8f98;
  font-size: 22rpx;
  text-align: center;
}
